# AI-Morning-Brief 비밀값 설정
# 이 파일을 .env로 복사하고 실제 값을 채우세요:
#   cp config/.env.example .env
#
# .env 파일은 절대 커밋하지 마세요 (.gitignore에 포함됨)

# Anthropic API 키 (Claude 분석에 사용)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord 웹훅 URL (브리핑 전송에 사용)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# 경로 override (선택사항 — 테스트 격리 등에 사용)
# MORNINGBRIEF_DB=/path/to/custom/morning_brief.db
# MORNINGBRIEF_RAW_DIR=/path/to/custom/raw
# MORNINGBRIEF_REPORTS_DIR=/path/to/custom/reports
